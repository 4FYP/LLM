# ── Odoo Connection ───────────────────────────────────────────────────────────
# URL of your Odoo instance (no trailing slash)
ODOO_URL=http://localhost:8069

# Database name
ODOO_DB=mycompany

# Odoo user login
ODOO_USER=admin

# Odoo user password
ODOO_PASSWORD=admin

# ── DeepSeek AI ───────────────────────────────────────────────────────────────
# Get your key at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...

# deepseek-chat (V3, fast & smart) or deepseek-reasoner (R1, complex reasoning)
DEEPSEEK_MODEL=deepseek-chat

# API base (only change for custom / local DeepSeek deployments)
DEEPSEEK_API_BASE=https://api.deepseek.com

# Generation settings
DEEPSEEK_TEMPERATURE=0.0
DEEPSEEK_MAX_TOKENS=4096

# Max agentic tool-call iterations per user turn
MAX_ITERATIONS=15

# ── Bill image scanning (vendor bills from photos) ────────────────────────────
# Uses free OCR: pip install pillow pytesseract && sudo apt install tesseract-ocr
# BILL_STRUCTURE_TIMEOUT=60

# ── Gunicorn production (REQUIRED on server — default 30s kills bill/chat requests) ──
# GUNICORN_TIMEOUT=300
# GUNICORN_WORKERS=2
# Start: ./run_gunicorn.sh

# ── Safety ────────────────────────────────────────────────────────────────────
# Set to false to make the agent read-only (no create/write/delete)
ALLOW_MUTATIONS=true

# Comma-separated list of models the AI cannot access
BLOCKED_MODELS=res.users,ir.rule,ir.model.access

# ── HTTP Server ───────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# ── Google OAuth (Continue with Google) ───────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Must match exactly what you add in Google Cloud Console → Credentials → Redirect URIs
GOOGLE_REDIRECT_URI=http://localhost:8765/auth/google/callback
